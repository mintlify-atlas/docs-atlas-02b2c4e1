{
  "projectType": "sdk-library",
  "projectName": "fast_opengl",
  "projectDescription": "A fast, easy-to-use C++ library providing functional abstractions over OpenGL 3.3+ for rendering shapes, loading OBJ models, managing textures, and simulating basic physics.",
  "theme": "palm",
  "primaryColor": "#00A86B",
  "lightColor": "#00C97F",
  "darkColor": "#007A4F",
